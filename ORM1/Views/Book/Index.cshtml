@model IEnumerable<ORM1.Models.Book>

<h2>Danh sách Book</h2>

<p>
    <a asp-action="Create" class="btn btn-success">Thêm mới</a>
</p>

<table class="table table-bordered">

    <tr>
        <th>ID</th>
        <th>Title</th>
        <th>Author</th>
        <th>Price</th>
        <th>Publish Year</th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Title</td>
            <td>@item.Author</td>
            <td>@item.Price</td>
            <td>@item.PublishYear</td>

            <td>
                <a asp-action="Edit"
                   asp-route-id="@item.Id"
                   class="btn btn-warning">
                    Edit
                </a>

                <a asp-action="Delete"
                   asp-route-id="@item.Id"
                   class="btn btn-danger">
                    Delete
                </a>
            </td>

        </tr>
    }

</table>